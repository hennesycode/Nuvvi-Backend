DJANGO_SECRET_KEY=nuvvi-dev-secret-key-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development
ENVIRONMENT=development

DATABASE_URL=postgresql://nuvvi:nuvvi_password@db:5432/nuvvi_db
POSTGRES_DB=nuvvi_db
POSTGRES_USER=nuvvi
POSTGRES_PASSWORD=nuvvi_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0

CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
CSRF_TRUSTED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

DEFAULT_SUPERUSER_EMAIL=admin@nuvvi.local
DEFAULT_SUPERUSER_PASSWORD=Admin12345*
DEFAULT_SUPERUSER_NAME=Super Admin Nuvvi

MATIAS_API_BASE_URL=
MATIAS_API_KEY=
MATIAS_API_SECRET=
DIAN_ENVIRONMENT=sandbox
